{
  "animations": [
    {
      "selector": ".w-lightbox-spinner",
      "animation": "0.8s linear 0s infinite normal none running spin"
    },
    {
      "selector": ".iPjsPC::before",
      "animation": "1.5s ease-in-out 0s infinite alternate none running eYuqoB"
    },
    {
      "selector": ".dqqATH",
      "animation": "1.2s linear 0s infinite normal none running fYAlao"
    },
    {
      "selector": ".dqqzKe",
      "animation": "1.2s linear 0.1s infinite normal none running fYAlao"
    },
    {
      "selector": ".dqqAgp",
      "animation": "1.2s linear 0.2s infinite normal none running fYAlao"
    }
  ],
  "keyframes": [
    {
      "name": "spin",
      "cssText": "@keyframes spin { \n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}"
    },
    {
      "name": "eYuqoB",
      "cssText": "@keyframes eYuqoB { \n  0% { opacity: 0.4; }\n  100% { opacity: 1; }\n}"
    },
    {
      "name": "fYAlao",
      "cssText": "@keyframes fYAlao { \n  0%, 100% { opacity: 0.4; }\n  50% { opacity: 0.75; }\n}"
    }
  ],
  "transitions": [
    {
